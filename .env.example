# BigQuery MCP Server Configuration
# ==================================

# Required: GCP Project ID
BIGQUERY_PROJECT=your-gcp-project-id

# Required: BigQuery dataset location (e.g., US, EU, us-central1)
BIGQUERY_LOCATION=US

# Optional: Filter to specific datasets (comma-separated)
BIGQUERY_DATASETS=dataset1,dataset2

# ============================================
# Authentication (choose ONE method)
# ============================================

# Method 1: Mount key file (RECOMMENDED)
# Mount the key file into container and set this path:
# docker run -v /path/to/key.json:/credentials/key.json:ro ...
BIGQUERY_KEY_FILE=/credentials/key.json

# Method 2: JSON credentials directly (NOT recommended - can leak in logs)
# BIGQUERY_CREDENTIALS={"type": "service_account", ...}

# Method 3: Use GOOGLE_APPLICATION_CREDENTIALS (standard GCP way)
# Mount key file and set this env var:
# GOOGLE_APPLICATION_CREDENTIALS=/credentials/key.json

# ============================================
# Transport Configuration
# ============================================

# Transport type: stdio (default) or sse (HTTP server)
MCP_TRANSPORT=sse

# Port for SSE transport (default: 8000)
MCP_PORT=8000
